---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'GitOps Blog',
	description = '一个使用 Astro 和 MDX 构建的博客',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<nav class="nav">
				<a class="brand" href="/">GitOps Blog</a>
				<div class="nav-links">
					<a href="/blog">博客</a>
					<a href="/about">关于</a>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
			"Segoe UI", sans-serif;
		background: #f7f7f4;
		color: #1f2933;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
			#f7f7f4;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	main {
		width: min(100%, 1040px);
		margin: 0 auto;
		padding: 40px 20px 72px;
	}

	.site-header {
		border-bottom: 1px solid #e2e0d8;
		background: rgba(247, 247, 244, 0.86);
		backdrop-filter: blur(16px);
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(100%, 1040px);
		margin: 0 auto;
		padding: 18px 20px;
	}

	.brand {
		font-weight: 760;
	}

	.nav-links {
		display: flex;
		gap: 18px;
		color: #52606d;
		font-size: 0.96rem;
	}

	.nav-links a:hover,
	.brand:hover {
		color: #0f766e;
	}

	:global(.eyebrow) {
		margin: 0 0 10px;
		color: #0f766e;
		font-size: 0.86rem;
		font-weight: 720;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	:global(.page-title) {
		margin: 0;
		max-width: 760px;
		font-size: clamp(2.25rem, 7vw, 4.7rem);
		line-height: 0.98;
		letter-spacing: 0;
	}

	:global(.lede) {
		max-width: 680px;
		margin: 20px 0 0;
		color: #52606d;
		font-size: 1.1rem;
		line-height: 1.75;
	}

	:global(.post-grid) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 18px;
		margin-top: 34px;
	}

	:global(.post-card) {
		display: flex;
		min-height: 232px;
		flex-direction: column;
		justify-content: space-between;
		border: 1px solid #dfddd4;
		border-radius: 8px;
		padding: 22px;
		background: #ffffff;
		box-shadow: 0 14px 30px rgba(31, 41, 51, 0.06);
	}

	:global(.post-card:hover) {
		border-color: #0f766e;
		transform: translateY(-2px);
	}

	:global(.post-card h2) {
		margin: 0 0 10px;
		font-size: 1.45rem;
		letter-spacing: 0;
	}

	:global(.post-card p) {
		margin: 0;
		color: #52606d;
		line-height: 1.65;
	}

	:global(.post-meta) {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 18px;
		color: #697586;
		font-size: 0.9rem;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 18px;
	}

	:global(.tag) {
		border: 1px solid #d6d3c8;
		border-radius: 999px;
		padding: 5px 10px;
		color: #31515a;
		background: #fbfaf7;
		font-size: 0.82rem;
	}

	:global(.article) {
		max-width: 760px;
	}

	:global(.article h1) {
		margin: 10px 0 18px;
		font-size: clamp(2.1rem, 6vw, 4rem);
		line-height: 1.04;
		letter-spacing: 0;
	}

	:global(.article-content) {
		margin-top: 34px;
		color: #2f3a45;
		font-size: 1.05rem;
		line-height: 1.85;
	}

	:global(.article-content a) {
		color: #0f766e;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	:global(.article-content pre) {
		overflow-x: auto;
		border-radius: 8px;
		padding: 16px;
		background: #172026;
		color: #f8fafc;
	}

	@media (max-width: 640px) {
		main {
			padding-top: 30px;
		}

		.nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 12px;
		}
	}
</style>
