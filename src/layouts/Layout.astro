---
import { getCollection } from 'astro:content';

interface Props {
	title?: string;
	description?: string;
	ogType?: 'website' | 'article';
}

const settings = await getCollection('settings');
const site = settings.find((entry) => entry.id === 'site')?.data;
const {
	title = site?.siteName ?? 'GitOps Blog',
	description = site?.description ?? '一个使用 Astro 和 MDX 构建的博客',
	ogType = 'website',
} = Astro.props;
const siteName = site?.siteName ?? 'GitOps Blog';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const navigation = site?.navigation?.length
	? site.navigation
	: [
			{ label: '首页', href: '/' },
			{ label: '博客', href: '/blog' },
			{ label: '标签', href: '/tags' },
			{ label: '关于', href: '/about' },
		];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={siteName} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<nav class="nav">
				<a class="brand" href="/">{siteName}</a>
				<div class="nav-links">
					{navigation.map((item) => <a href={item.href}>{item.label}</a>)}
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
			"Segoe UI", sans-serif;
		background: #f7f7f4;
		color: #1f2933;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
	}

	body {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(255, 255, 255, 0)),
			#f7f7f4;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	main {
		width: min(100%, 1040px);
		margin: 0 auto;
		padding: 40px 20px 72px;
	}

	.site-header {
		border-bottom: 1px solid #e2e0d8;
		background: rgba(247, 247, 244, 0.86);
		backdrop-filter: blur(16px);
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: min(100%, 1040px);
		margin: 0 auto;
		padding: 18px 20px;
	}

	.brand {
		font-weight: 760;
	}

	.nav-links {
		display: flex;
		gap: 18px;
		color: #52606d;
		font-size: 0.96rem;
	}

	.nav-links a:hover,
	.brand:hover {
		color: #0f766e;
	}

	:global(.eyebrow) {
		margin: 0 0 10px;
		color: #0f766e;
		font-size: 0.86rem;
		font-weight: 720;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	:global(.page-title) {
		margin: 0;
		max-width: 760px;
		font-size: clamp(2.25rem, 7vw, 4.7rem);
		line-height: 0.98;
		letter-spacing: 0;
	}

	:global(.lede) {
		max-width: 680px;
		margin: 20px 0 0;
		color: #52606d;
		font-size: 1.1rem;
		line-height: 1.75;
	}

	:global(.post-grid) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 18px;
		margin-top: 34px;
	}

	:global(.post-card) {
		border: 1px solid #dfddd4;
		border-radius: 8px;
		background: #ffffff;
		box-shadow: 0 14px 30px rgba(31, 41, 51, 0.06);
		transition:
			border-color 160ms ease,
			transform 160ms ease;
	}

	:global(.post-card-link) {
		display: flex;
		min-height: 232px;
		flex-direction: column;
		justify-content: space-between;
		padding: 22px;
	}

	:global(.post-card:hover) {
		border-color: #0f766e;
		transform: translateY(-2px);
	}

	:global(.post-card h2) {
		margin: 0 0 10px;
		font-size: 1.45rem;
		letter-spacing: 0;
	}

	:global(.post-card p) {
		margin: 0;
		color: #52606d;
		line-height: 1.65;
	}

	:global(.category-link) {
		display: inline-flex;
		margin-bottom: 10px;
		color: #0f766e;
		font-size: 0.86rem;
		font-weight: 720;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	:global(.category-link:hover) {
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	:global(.post-meta) {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 18px;
		color: #697586;
		font-size: 0.9rem;
	}

	:global(.tag-list) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 18px;
	}

	:global(.tag) {
		border: 1px solid #d6d3c8;
		border-radius: 999px;
		padding: 5px 10px;
		color: #31515a;
		background: #fbfaf7;
		font-size: 0.82rem;
	}

	:global(a.tag:hover) {
		border-color: #0f766e;
		color: #0f766e;
	}

	:global(.term-list) {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 12px;
		margin-top: 32px;
	}

	:global(.term-card) {
		display: flex;
		align-items: center;
		justify-content: space-between;
		border: 1px solid #dfddd4;
		border-radius: 8px;
		padding: 16px 18px;
		background: #fff;
		color: #2f3a45;
	}

	:global(.term-card:hover) {
		border-color: #0f766e;
		color: #0f766e;
	}

	:global(.term-count) {
		color: #697586;
		font-size: 0.9rem;
	}

	:global(.article) {
		display: grid;
		grid-template-columns: minmax(0, 760px) 220px;
		gap: 44px;
		align-items: start;
	}

	:global(.article h1) {
		margin: 10px 0 18px;
		font-size: clamp(2.1rem, 6vw, 4rem);
		line-height: 1.04;
		letter-spacing: 0;
	}

	:global(.article-main) {
		min-width: 0;
	}

	:global(.article-author) {
		display: flex;
		gap: 12px;
		align-items: center;
		border-top: 1px solid #dfddd4;
		margin-top: 26px;
		padding-top: 18px;
		color: #52606d;
	}

	:global(.author-avatar) {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		object-fit: cover;
		background: #e8e4da;
	}

	:global(.author-name) {
		margin: 0;
		color: #1f2933;
		font-weight: 720;
	}

	:global(.author-bio) {
		margin: 3px 0 0;
		font-size: 0.92rem;
		line-height: 1.5;
	}

	:global(.toc) {
		position: sticky;
		top: 24px;
		border-left: 1px solid #dfddd4;
		padding-left: 18px;
		color: #52606d;
		font-size: 0.92rem;
	}

	:global(.toc-title) {
		margin: 0 0 12px;
		color: #1f2933;
		font-weight: 760;
	}

	:global(.toc ol) {
		display: grid;
		gap: 8px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	:global(.toc a:hover) {
		color: #0f766e;
	}

	:global(.article-content) {
		margin-top: 34px;
		color: #2f3a45;
		font-size: 1.05rem;
		line-height: 1.85;
	}

	:global(.article-content a) {
		color: #0f766e;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	:global(.article-content h2),
	:global(.article-content h3),
	:global(.article-content h4) {
		margin-top: 2.2em;
		color: #1f2933;
		letter-spacing: 0;
		line-height: 1.25;
	}

	:global(.article-content img) {
		max-width: 100%;
		border-radius: 8px;
		border: 1px solid #dfddd4;
	}

	:global(.article-content code) {
		border-radius: 5px;
		padding: 0.16em 0.36em;
		background: #e9f2ef;
		color: #0f5f59;
		font-size: 0.92em;
	}

	:global(.article-content pre) {
		overflow-x: auto;
		border-radius: 8px;
		border: 1px solid #26323a;
		padding: 18px;
		background: #172026;
		color: #f8fafc;
	}

	:global(.article-content pre code) {
		padding: 0;
		background: transparent;
		color: inherit;
		font-size: 0.95rem;
	}

	@media (max-width: 640px) {
		main {
			padding-top: 30px;
		}

		.nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 12px;
		}
	}

	@media (max-width: 900px) {
		:global(.article) {
			display: block;
		}

		:global(.toc) {
			position: static;
			margin-top: 30px;
			border-left: 0;
			border-top: 1px solid #dfddd4;
			padding: 18px 0 0;
		}
	}
</style>
