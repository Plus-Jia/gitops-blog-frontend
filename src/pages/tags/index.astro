---
import Layout from '../../layouts/Layout.astro';
import { getAllTags, getPublishedPosts } from '../../lib/content';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<Layout title="标签 | GitOps Blog" description="按标签浏览全部文章">
	<section>
		<p class="eyebrow">Tags</p>
		<h1 class="page-title">标签</h1>
		<p class="lede">按主题快速找到相关文章。</p>
	</section>

	<section class="term-list" aria-label="标签列表">
		{
			tags.map((tag) => (
				<a class="term-card" href={`/tags/${encodeURIComponent(tag.name)}`}>
					<span>{tag.name}</span>
					<span class="term-count">{tag.count} 篇</span>
				</a>
			))
		}
	</section>
</Layout>
