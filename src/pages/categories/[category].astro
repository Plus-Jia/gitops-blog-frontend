---
import PostCard from '../../components/PostCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getAllCategories, getPublishedPosts, postsByCategory } from '../../lib/content';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();

	return getAllCategories(posts).map((category) => ({
		params: { category: category.name },
		props: {
			category: category.name,
			posts: postsByCategory(posts, category.name),
		},
	}));
}

const { category, posts } = Astro.props;
---

<Layout
	title={`分类：${category} | GitOps Blog`}
	description={`浏览分类 ${category} 下的文章`}
>
	<section>
		<p class="eyebrow">Category</p>
		<h1 class="page-title">{category}</h1>
		<p class="lede">共 {posts.length} 篇文章。</p>
	</section>

	<section class="post-grid" aria-label={`${category} 分类文章列表`}>
		{posts.map((post) => <PostCard post={post} />)}
	</section>
</Layout>
