---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Layout title="博客列表 | GitOps Blog" description="全部已发布博客文章">
	<section>
		<p class="eyebrow">Blog</p>
		<h1 class="page-title">博客文章</h1>
		<p class="lede">这里展示所有非草稿文章，按发布时间倒序排列。</p>
	</section>

	<section class="post-grid" aria-label="博客文章列表">
		{
			posts.map((post) => (
				<a class="post-card" href={`/blog/${post.id}`}>
					<div>
						<p class="eyebrow">{post.data.category}</p>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
					</div>
					<div>
						<div class="tag-list">
							{post.data.tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
						<div class="post-meta">
							<time datetime={post.data.pubDate.toISOString()}>
								{dateFormatter.format(post.data.pubDate)}
							</time>
							{post.data.featured && <span>精选</span>}
						</div>
					</div>
				</a>
			))
		}
	</section>
</Layout>
