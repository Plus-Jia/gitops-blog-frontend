---
import PostCard from '../components/PostCard.astro';
import Layout from '../layouts/Layout.astro';
import { getAllCategories, getAllTags, getPublishedPosts } from '../lib/content';

const allPosts = await getPublishedPosts();
const posts = allPosts.slice(0, 6);
const tags = getAllTags(allPosts).slice(0, 12);
const categories = getAllCategories(allPosts);
---

<Layout title="GitOps Blog" description="记录云原生、GitOps 与工程实践的 Astro 博客">
	<section>
		<p class="eyebrow">Astro + MDX</p>
		<h1 class="page-title">记录云原生与 GitOps 实践</h1>
		<p class="lede">
			一个干净的 Astro 博客起点，使用 Content Collections 管理文章，
			支持 MDX 内容和草稿过滤。
		</p>
	</section>

	<section class="post-grid" aria-label="最新文章">
		{posts.map((post) => <PostCard post={post} />)}
	</section>

	<section class="home-taxonomy" aria-label="内容索引">
		<div>
			<h2>标签</h2>
			<div class="tag-list">
				{tags.map((tag) => <a class="tag" href={`/tags/${encodeURIComponent(tag.name)}`}>{tag.name}</a>)}
			</div>
		</div>
		<div>
			<h2>分类</h2>
			<div class="tag-list">
				{
					categories.map((category) => (
						<a class="tag" href={`/categories/${encodeURIComponent(category.name)}`}>
							{category.name}
						</a>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<style>
	.home-taxonomy {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 26px;
		margin-top: 52px;
		border-top: 1px solid #dfddd4;
		padding-top: 32px;
	}

	.home-taxonomy h2 {
		margin: 0 0 14px;
		font-size: 1.1rem;
		letter-spacing: 0;
	}
</style>
